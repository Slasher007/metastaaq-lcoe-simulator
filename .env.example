# Supabase Configuration
# Copy this file to .env and fill in your Supabase credentials

# Your Supabase project URL (found in Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (found in Settings > API)
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key for admin operations (keep secret!)
# SUPABASE_SERVICE_KEY=your-service-role-key-here
